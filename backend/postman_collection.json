    {
      "name": "Sync - enviar lote de loans (Service Worker)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenantId\": \"<TENANT_UUID>\",\n  \"transactions\": [\n    {\n      \"userId\": \"<USER_UUID>\",\n      \"bookId\": \"<BOOK_UUID>\",\n      \"loanDate\": \"2026-06-01T12:00:00Z\",\n      \"status\": \"BORROWED\"\n    }\n  ]\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/sync/loans", "host": ["{{baseUrl}}"], "path": ["api","sync","loans"] }
      },
      "response": []
    },
