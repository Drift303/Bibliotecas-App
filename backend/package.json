{
  "name": "biblioteka-backend",
  "version": "0.1.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js --watch . --ext js,json --delay 200",
    "start": "npx prisma db push --accept-data-loss && node server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "node prisma/seed.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@getbrevo/brevo": "^6.0.2",
    "@prisma/client": "^6.10.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^9.0.3",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "prisma": "^6.10.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  }
}
